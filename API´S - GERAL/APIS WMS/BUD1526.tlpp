/* ----------------------------------------- */

/*
/==================================================================================\
|Nome              : Cadastrar NotaDevolucao                                       |
|==================================================================================|
|Descricao         : Este metodo realiza o cadastro de notas de devolucao          |
|                  : em poder de terceiro                                          |
|==================================================================================|
|Autor             : Daniel Victor da Rosa - Personalitec                          |
|==================================================================================|
|Data de Criacao   : 19/05/2026                                                    |
\==================================================================================/
*/

Method cadastrar() as Logical Class Cadastrar

	// Declara as variaveis
	Local lMsErroAuto := .F. as Logical
	Local lRetorno    := .T. as Logical

	Local iX := 0 as Integer
	Local iY := 0 as Integer

	Local dDataNf := Date() as Date

	Local cDocNf      := "" as Character
	Local cAutoDeleta := "N" as Character
	Local cRetorno    := "" as Character
	Local cBody       := "" as Character

	Local aAutoErro := {} as Array
	Local aCabec    := {} as Array
	Local aItens    := {} as Array
	Local aLinha    := {} as Array

	Local oBody := JsonObject():New()

	Public oRetorno  := JsonObject():New() as Object
	Public jJsonItem := JsonObject():New() as Json

	_Super:New() 
	oRetorno["retorno"] := {}

	cBody := oRest:getBodyRequest()
	oBody:fromJson(DecodeUTF8(cBody))

	For iX := 1 To Len(oBody)

		lRetorno := .T.
		aCabec   := {}
		aItens   := {}
		jJsonItem := JsonObject():New()

		If !oBody[iX]:HasProperty("fwfornecedor") .OR. Empty(oBody[iX]["fwfornecedor"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwfornecedor) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 1
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwlojafornecedor") .OR. Empty(oBody[iX]["fwlojafornecedor"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwlojafornecedor) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 2
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwitensorigem")
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwitensorigem) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 3
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwnforigem") .OR. Empty(oBody[iX]["fwnforigem"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwnforigem) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 4
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwserieorigem") .OR. Empty(oBody[iX]["fwserieorigem"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwserieorigem) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 5
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwidentb6") .OR. Empty(oBody[iX]["fwidentb6"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwidentb6) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 6
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwserienf") .OR. Empty(oBody[iX]["fwserienf"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwserienf) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 7
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwtes") .OR. Empty(oBody[iX]["fwtes"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwtes) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 8
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwcf") .OR. Empty(oBody[iX]["fwcf"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwcf) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 9
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwtipo") .OR. Empty(oBody[iX]["fwtipo"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwtipo) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 10
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwformul") .OR. Empty(oBody[iX]["fwformul"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwformul) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 11
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwespecie") .OR. Empty(oBody[iX]["fwespecie"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwespecie) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 12
			lRetorno             := .F.

		ElseIf !oBody[iX]:HasProperty("fwcondicaopag") .OR. Empty(oBody[iX]["fwcondicaopag"])
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "O campo (fwcondicaopag) e obrigatorio e nao pode ser vazio!"
			jJsonItem["code"]    := 13
			lRetorno             := .F.

		ElseIf Len(oBody[iX]["fwitensorigem"]) == 0
			jJsonItem["item"]    := iX
			jJsonItem["message"] := "Nenhum item foi enviado em (fwitensorigem)!"
			jJsonItem["code"]    := 14
			lRetorno             := .F.

		EndIf

		If lRetorno
			For iY := 1 To Len(oBody[iX]["fwitensorigem"])

				If !oBody[iX]["fwitensorigem"][iY]:HasProperty("fwquantidade")
					jJsonItem["item"]    := iX
					jJsonItem["subitem"] := iY
					jJsonItem["message"] := "O campo (fwquantidade) e obrigatorio"
					jJsonItem["code"]    := 15
					lRetorno             := .F.
					Exit

				ElseIf !oBody[iX]["fwitensorigem"][iY]:HasProperty("fwvalorunitario")
					jJsonItem["item"]    := iX
					jJsonItem["subitem"] := iY
					jJsonItem["message"] := "O campo (fwvalorunitario) e obrigatorio"
					jJsonItem["code"]    := 16
					lRetorno             := .F.
					Exit

				ElseIf !oBody[iX]["fwitensorigem"][iY]:HasProperty("fwvalortotal")
					jJsonItem["item"]    := iX
					jJsonItem["subitem"] := iY
					jJsonItem["message"] := "O campo (fwvalortotal) e obrigatorio"
					jJsonItem["code"]    := 17
					lRetorno             := .F.
					Exit

				ElseIf !oBody[iX]["fwitensorigem"][iY]:HasProperty("fwitemorigem") .OR. Empty(oBody[iX]["fwitensorigem"][iY]["fwitemorigem"])
					jJsonItem["item"]    := iX
					jJsonItem["subitem"] := iY
					jJsonItem["message"] := "O campo (fwitemorigem) e obrigatorio e nao pode ser vazio!"
					jJsonItem["code"]    := 18
					lRetorno             := .F.
					Exit

				ElseIf !oBody[iX]["fwitensorigem"][iY]:HasProperty("fwitemprodutoorigem") .OR. Empty(oBody[iX]["fwitensorigem"][iY]["fwitemprodutoorigem"])
					jJsonItem["item"]    := iX
					jJsonItem["subitem"] := iY
					jJsonItem["message"] := "O campo (fwitemprodutoorigem) e obrigatorio e nao pode ser vazio!"
					jJsonItem["code"]    := 19
					lRetorno             := .F.
					Exit

				EndIf

			Next iY
		EndIf

		If lRetorno
			::setFornecedor(oBody[iX]["fwfornecedor"])
			::setLojaFornecedor(oBody[iX]["fwlojafornecedor"])
			::setItensOrigem(oBody[iX]["fwitensorigem"])
			::setNfOrigem(oBody[iX]["fwnforigem"])
			::setSerieOrigem(oBody[iX]["fwserieorigem"])
			::setIdentB6(oBody[iX]["fwidentb6"])
			::setSerieNf(oBody[iX]["fwserienf"])
			::setTes(oBody[iX]["fwtes"])
			::setCf(oBody[iX]["fwcf"])
			::setTipo(oBody[iX]["fwtipo"])
			::setFormul(oBody[iX]["fwformul"])
			::setEspecie(oBody[iX]["fwespecie"])
			::setCondicaoPag(oBody[iX]["fwcondicaopag"])

			cDocNf := GetSxeNum("SF1", "F1_DOC")

			aAdd(aCabec, {"F1_TIPO",    ::getTipo(),           Nil})
			aAdd(aCabec, {"F1_FORMUL",  ::getFormul(),         Nil})
			aAdd(aCabec, {"F1_DOC",     cDocNf,                Nil})
			aAdd(aCabec, {"F1_SERIE",   ::getSerieNf(),        Nil})
			aAdd(aCabec, {"F1_EMISSAO", dDataNf,               Nil})
			aAdd(aCabec, {"F1_FORNECE", ::getFornecedor(),     Nil})
			aAdd(aCabec, {"F1_LOJA",    ::getLojaFornecedor(), Nil})
			aAdd(aCabec, {"F1_ESPECIE", ::getEspecie(),        Nil})
			aAdd(aCabec, {"F1_COND",    ::getCondicaoPag(),    Nil})

			For iY := 1 To Len(::getItensOrigem())

				aLinha := {}

				::setQuantidade(::getItensOrigem()[iY]["fwquantidade"])
				::setValorUnitario(::getItensOrigem()[iY]["fwvalorunitario"])
				::setValorTotal(::getItensOrigem()[iY]["fwvalortotal"])
				::setItemOrigem(::getItensOrigem()[iY]["fwitemorigem"])
				::setItemProdutoOrigem(::getItensOrigem()[iY]["fwitemprodutoorigem"])

				aAdd(aLinha, {"D1_ITEM",    StrZero(iY, 3),           Nil})
				aAdd(aLinha, {"D1_COD",     ::getItemProdutoOrigem(),  Nil})
				aAdd(aLinha, {"D1_QUANT",   ::getQuantidade(),         Nil})
				aAdd(aLinha, {"D1_VUNIT",   ::getValorUnitario(),      Nil})
				aAdd(aLinha, {"D1_TOTAL",   ::getValorTotal(),         Nil})
				aAdd(aLinha, {"D1_TES",     ::getTes(),                Nil})
				aAdd(aLinha, {"D1_CF",      ::getCf(),                 Nil})
				aAdd(aLinha, {"D1_DOC",     cDocNf,                    Nil})
				aAdd(aLinha, {"D1_SERIE",   ::getSerieNf(),            Nil})
				aAdd(aLinha, {"D1_EMISSAO", dDataNf,                   Nil})
				aAdd(aLinha, {"D1_NFORI",   ::getNfOrigem(),           Nil})
				aAdd(aLinha, {"D1_SERIORI", ::getSerieOrigem(),        Nil})
				aAdd(aLinha, {"D1_ITEMORI", ::getItemOrigem(),         Nil})
				aAdd(aLinha, {"D1_IDENTB6", ::getIdentB6(),            Nil})
				aAdd(aLinha, {"AUTDELETA",  cAutoDeleta,               Nil})
				aAdd(aItens, aLinha)

			Next iY

			lMsErroAuto := .F.

			MSExecAuto({|x,y,z| Mata103(x,y,z)}, aCabec, aItens, 3)

			If !lMsErroAuto
				jJsonItem["message"]  := "Documento de devolucao incluido com sucesso."
				jJsonItem["code"]     := 200
				jJsonItem["F1_DOC"]   := cDocNf
				jJsonItem["F1_SERIE"] := ::getSerieNf()
				jJsonItem["D1_NFORI"] := ::getNfOrigem()
			Else
				jJsonItem["message"]  := "Documento de devolucao nao incluido"
				jJsonItem["code"]     := 400
				jJsonItem["F1_DOC"]   := ""
				jJsonItem["F1_SERIE"] := ""
				jJsonItem["D1_NFORI"] := ::getNfOrigem()
			EndIf
		EndIf

		aAdd(oRetorno["retorno"], jJsonItem)
		ConOut("[API FATURAMENTO] - " + AllTrim(Str(jJsonItem["code"])) + " - " + jJsonItem["message"])

	Next iX

	Begin Sequence

		oRest:setResponse(EncodeUtf8(oRetorno:toJson()))
		oRest:setStatusCode(200)

		Recover

		oRest:setResponse(EncodeUtf8("{error:Internal Server Error}"))
		oRest:setStatusCode(500)

	End Sequence

Return .T.
