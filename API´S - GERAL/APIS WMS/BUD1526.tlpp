Public Method getValorTotal() as Double
Public Method getQuantidade() as Double
Public Method getItemOrigem() as Character
Public Method getItemProdutoOrigem() as Character
Public Method getSerieNf() as Character
Public Method getTes() as Character
Public Method getCf() as Character
Public Method getTipo() as Character
Public Method getFormul() as Character
Public Method getEspecie() as Character
Public Method getCondicaoPag() as Character

Public Method setFornecedor(c)
Public Method setLojaFornecedor(c)
Public Method setItensOrigem(a)
Public Method setNfOrigem(c)
Public Method setSerieOrigem(c)
Public Method setIdentB6(c)
Public Method setValorUnitario(e)
Public Method setValorTotal(e)
Public Method setQuantidade(e)
Public Method setItemOrigem(c)
Public Method setItemProdutoOrigem(c)
