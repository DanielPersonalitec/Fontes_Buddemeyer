Public Method getCodProduto() as Character
Public Method getBarQuery() as Character
Public Method getUnidade() as Character
Public Method getQtdePct() as Character
Public Method getCodBarra() as Character
Public Method getQtdEstoque() as Character
Public Method getCodLocal() as Character
Public Method getCustoStandard() as Character
Public Method getGrupo() as Character
Public Method getLargura() as Character
Public Method getTipo() as Character
Public Method getOrigem() as Character
Public Method getDescProduto() as Character
Public Method getCNumQuery() as Character
Public Method getFiltro() as Character

Public Method setCodProduto(c)
Public Method setUnidade(c)
Public Method setBarQuery(c)
Public Method setQtdePct(c)
Public Method setCodBarra(c)
Public Method setCodLocal(c)
Public Method setQtdEstoque(c)
Public Method setCustoStandard(c)
Public Method setGrupo(c)
Public Method setLargura(c)
Public Method setTipo(c)
Public Method setOrigem(c)
Public Method setDescProduto(c)
Public Method setCNumQuery(c)
Public Method setFiltro(c)

Public Method dados() as Logical
EndInterface

Interface prodInterfacepost
Public Method New()
Public Method getProduto() as Character
Public Method getlargura() as Numeric
Public Method getdescricao() as Character
Public Method setdescricao(c)
Public Method setproduto(c)
Public Method setlargura(c)
EndInterface

Interface alteraInterface
Public Method New()
Public Method updateB1()
EndInterface

Interface ConsultarInterface
Public Method New()
Public Method consultar() as Logical
EndInterface

