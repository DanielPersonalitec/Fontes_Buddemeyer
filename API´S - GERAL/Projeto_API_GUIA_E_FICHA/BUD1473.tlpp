EndClass

Class postproduto Implements prodInterfacepost
    Private data cProduto as Character
    Private data nlargura as Numeric
    Private data cdescricao as Character

    Public Method New()
    Public Method getProduto() as Character
    Public Method getlargura() as Numeric
    Public Method getdescricao() as Character
    Public Method setdescricao(c)
    Public Method setproduto(c)
    Public Method setlargura(c)

EndClass

Class Consultar From Produto Implements ConsultarInterface
    Public Method New()

    @Get("/api_produtos/consultar/:codproduto/:codlocal/:codbar/:cnumquery/:filtro")
    Public Method consultar() as Logical

EndClass


Class Update From postproduto Implements alteraInterface
    Public Method New()

    @Post("api_produtos/updateB1")
    Public Method updateB1()

EndClass

